    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst tgId = String($('Webhook').item.json.body.message.chat.id);\nconst userText = $('Webhook').item.json.body.message.text;\nconst systemPrompt = $('Get a prompt').item.json.content;\n\n// Инициализируем историю для нового юзера\nif (!staticData[tgId]) {\n  staticData[tgId] = [];\n}\n\n// Добавляем новое сообщение юзера\nstaticData[tgId].push({\n  role: 'user',\n  content: userText\n});\n\n// Обрезаем до последних 20 сообщений (как reset_context в growbot)\nif (staticData[tgId].length > 10) {\n  staticData[tgId] = staticData[tgId].slice(-10);\n}\n\n// Собираем финальный массив: system + история\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...staticData[tgId]\n];\n\nreturn [{ json: { messages } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1712,
        -432
      ],
      "id": "13f47106-5c69-46ce-a189-79be66832cd7",
      "name": "Get context"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst tgId = String($('Webhook').item.json.body.message.chat.id);\nconst assistantReply = $('Create request').item.json.choices[0].message.content;\n\n// Инициализируем если вдруг пусто\nif (!staticData[tgId]) {\n  staticData[tgId] = [];\n}\n\nstaticData[tgId].push({\n  role: 'assistant',\n  content: assistantReply\n});\n\nreturn [{ json: { reply: assistantReply } }];"
      },
      "type": "n8n-nodes-base.code",
